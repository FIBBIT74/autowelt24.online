{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "preferences": {
          "type": "object",
          "properties": {
            "budget": { "type": "number" },
            "drivingHabits": { "type": "string" },
            "ecoPreference": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Car": {
      "title": "Car",
      "description": "Vehicle listing information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "make": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "number" },
        "price": { "type": "number" },
        "mileage": { "type": "number" },
        "fuelType": { "type": "string" },
        "transmission": { "type": "string" },
        "bodyType": { "type": "string" },
        "exteriorColor": { "type": "string" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "sellerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isVerified": { "type": "boolean" }
      },
      "required": ["make", "model", "year", "price", "sellerId"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between a buyer and a seller",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "carId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "GarageItem": {
      "title": "Garage Item",
      "description": "A saved car in a user's virtual garage",
      "type": "object",
      "properties": {
        "carId": { "type": "string" },
        "userId": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["saved", "comparing", "test-drive-scheduled"] },
        "testDriveDate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/cars/{carId}": { "schema": "Car", "description": "Car listings" },
    "/chats/{chatId}": { "schema": "Chat", "description": "Conversations" },
    "/chats/{chatId}/messages/{messageId}": { "schema": "Message", "description": "Chat messages" },
    "/users/{userId}/garage/{garageId}": { "schema": "GarageItem", "description": "User's virtual garage" }
  }
}
